"""Quick stats: B3 v1 vs B3 v2."""
import json

# B3 v1 (already completed)
with open("runs/b3.jsonl") as f:
    v1 = [json.loads(l) for l in f if l.strip()]

# B3 v2 (may not have completed yet)
try:
    with open("runs/b3_v2.jsonl") as f:
        v2 = [json.loads(l) for l in f if l.strip()]
except FileNotFoundError:
    v2 = None

def stats(name, records):
    if not records:
        print(f"{name}: NOT FOUND / EMPTY")
        return
    a = [r for r in records if r["kind"] in ("direct","indirect")]
    n = len(a) or 1
    lk = sum(1 for r in a if r["leaked"])
    cf = sum(1 for r in a if r.get("adjudicator_confirmed"))
    cb = sum(1 for r in a if r.get("adjudicator_action") == "conservative_block")
    rep = sum(1 for r in a if r.get("repair_action") == "repair")
    adj_raws = [r.get("adjudicator_raw","") for r in a if r.get("adjudicator_raw")]
    print(f"{name}:")
    print(f"  Records: {len(records)}, Attack: {len(a)}")
    print(f"  Leaked:  {lk}/{len(a)} = {lk/n*100:.1f}%")
    print(f"  Confirm: {cf}/{len(a)} = {cf/n*100:.1f}%")
    print(f"  ConservativeBlock: {cb}")
    print(f"  Repair action: {rep}")
    if adj_raws:
        print(f"  Adjudicator raw (first): {adj_raws[0][:200]}")
    print()

stats("B3 v1 (original adjudicator)", v1)
stats("B3 v2 (new adjudicator)", v2)

# If v2 available, compare key metrics
if v2 and v1:
    a1 = [r for r in v1 if r["kind"] in ("direct","indirect")]
    a2 = [r for r in v2 if r["kind"] in ("direct","indirect")]
    lk1 = sum(1 for r in a1 if r["leaked"])
    lk2 = sum(1 for r in a2 if r["leaked"])
    n1 = len(a1) or 1; n2 = len(a2) or 1
    print("=== Comparison ===")
    print(f"  B3 v1 CLR: {lk1/n1*100:.1f}%  |  B3 v2 CLR: {lk2/n2*100:.1f}%")
    delta = (lk2/n2 - lk1/n1) * 100
    d = "✅ BETTER" if delta < -1 else "⚠️ SAME" if abs(delta) <= 1 else "❌ WORSE"
    print(f"  Delta: {delta:+.1f}%  {d}")